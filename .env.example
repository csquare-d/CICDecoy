# CI/CDecoy — Environment Variables
#
# Copy this file to .env and customize as needed.
# docker-compose reads .env automatically from the repo root.
#
# All values below are the defaults — you only need to set
# variables you want to override.

# ── Ports ────────────────────────────────────────────
# SSH_DECOY_PORT=2222
# SSH_DECOY_TIER3_PORT=2223
# DASHBOARD_PORT=8080
# NATS_PORT=4222
# NATS_MONITOR_PORT=8222
# TIMESCALEDB_PORT=5432
# INFERENCE_PORT=8000
# OLLAMA_PORT=11434

# ── Database ─────────────────────────────────────────
# POSTGRES_USER=cicdecoy
# POSTGRES_PASSWORD=cicdecoy
# POSTGRES_DB=cicdecoy

# ── Logging ──────────────────────────────────────────
# LOG_LEVEL=DEBUG

# ── LLM (Tier 3 only) ───────────────────────────────
# OLLAMA_MODEL=llama3.2:3b
